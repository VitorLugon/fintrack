# Copie este arquivo para .env e ajuste a conexão com seu PostgreSQL.
#
# Em produção com Neon:
# - DATABASE_URL deve usar a conexão pooled, recomendada para a aplicação.
# - DIRECT_URL deve usar a conexão direta, recomendada para migrations do Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fintrack?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/fintrack?schema=public"

# Usado para assinar o cookie de sessão local.
# Em produção, use um valor longo e aleatório.
AUTH_SECRET="troque-este-segredo-local"
